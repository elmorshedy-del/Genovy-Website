{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genovy.ai/schemas/genereviews/chapter.schema.json",
  "title": "GeneReviewsChapter",
  "description": "Top-level container the orchestrator writes per chapter. Universal across all 200 chapters. One file per NBK id.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "chapter_id",
    "chapter_title",
    "genes",
    "diseases",
    "sections",
    "atoms",
    "coverage_audit",
    "run"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "chapter_id": {
      "type": "string",
      "pattern": "^NBK[0-9]+$"
    },
    "chapter_title": { "type": "string", "minLength": 1 },
    "chapter_version": {
      "type": ["string", "null"],
      "description": "Last revision date or version string captured from the chapter header."
    },
    "retrieval_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "retrieved_at": { "type": "string", "format": "date-time" },
    "genes": {
      "type": "array",
      "minItems": 0,
      "description": "Convenience hoist of genes named in the chapter. The universal contract is that gene identity is carried by atoms (kind = `identity`); this top-level array is a denormalized index for downstream consumers and may be empty when an extraction has not yet harvested identity atoms.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol"],
        "properties": {
          "symbol": { "type": "string", "minLength": 1 },
          "hgnc_curie": { "type": ["string", "null"], "pattern": "^HGNC:[0-9]+$" },
          "ncbi_gene_curie": { "type": ["string", "null"], "pattern": "^NCBIGene:[0-9]+$" },
          "ensembl_curie": { "type": ["string", "null"], "pattern": "^ENSEMBL:ENSG[0-9]+$" },
          "omim_gene_curie": { "type": ["string", "null"], "pattern": "^OMIM:[0-9]+$" }
        }
      }
    },
    "diseases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "mondo_curie": { "type": ["string", "null"], "pattern": "^MONDO:[0-9]+$" },
          "omim_curie": { "type": ["string", "null"], "pattern": "^OMIM:[0-9]+$" },
          "orphanet_curie": { "type": ["string", "null"], "pattern": "^Orphanet:[0-9]+$" },
          "synonyms": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "default": []
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "description": "Section slices the section splitter produced. The orchestrator dispatches one agent per slice.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lane", "section_path", "text", "char_offset"],
        "properties": {
          "lane": { "type": "string" },
          "section_path": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "text": { "type": "string", "minLength": 1 },
          "char_offset": {
            "type": "integer",
            "minimum": 0,
            "description": "Offset of this slice inside the chapter's normalized plain text."
          },
          "char_length": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "atoms": {
      "type": "array",
      "items": { "$ref": "https://genovy.ai/schemas/genereviews/assertion.schema.json" }
    },
    "coverage_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chapter_body_chars",
        "accounted_chars",
        "unassigned_chars",
        "dropped_chars",
        "unassigned_headings",
        "passes_accounting"
      ],
      "properties": {
        "chapter_body_chars": { "type": "integer", "minimum": 0 },
        "accounted_chars": {
          "type": "integer",
          "minimum": 0,
          "description": "Sum of `char_length` over every section slice (including `unassigned`)."
        },
        "unassigned_chars": { "type": "integer", "minimum": 0 },
        "dropped_chars": {
          "type": "integer",
          "minimum": 0,
          "description": "Bytes routed to droppable headings (References, Resources, Chapter Notes, etc.)."
        },
        "unassigned_headings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Distinct heading strings the splitter could not place. The coverage probe aggregates these across the batch."
        },
        "passes_accounting": {
          "type": "boolean",
          "description": "True iff accounted_chars + dropped_chars >= 0.95 * chapter_body_chars. False blocks ingestion to the production graph."
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at", "finished_at", "agents"],
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "providers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "model"],
            "properties": {
              "name": { "type": "string" },
              "model": { "type": "string" }
            }
          },
          "default": []
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["agent_id", "lane", "status"],
            "properties": {
              "agent_id": { "type": "string" },
              "lane": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["ok", "empty", "skipped", "failed"]
              },
              "atoms_emitted": { "type": "integer", "minimum": 0, "default": 0 },
              "atoms_kept": { "type": "integer", "minimum": 0, "default": 0 },
              "atoms_dropped_grounding": {
                "type": "integer",
                "minimum": 0,
                "default": 0
              },
              "atoms_flagged_review": {
                "type": "integer",
                "minimum": 0,
                "default": 0
              },
              "input_chars": { "type": "integer", "minimum": 0, "default": 0 },
              "duration_ms": { "type": "integer", "minimum": 0, "default": 0 },
              "error": { "type": ["string", "null"], "default": null }
            }
          }
        },
        "coverage_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "Fraction of expected lanes that produced at least one atom. Cheap completeness signal."
        }
      }
    }
  }
}
